    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this incoming email and produce a JSON decision.\n\nFrom: {{ $json.from }}\nSubject: {{ $json.subject }}\n\nBody:\n{{ $json.text }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a professional email assistant that triages an inbox and drafts replies.\n\nClassify the email into one of: \"genuine\", \"promotional\", \"spam\", \"newsletter\".\n- Set should_reply = true ONLY for \"genuine\" emails written by a real person that expect a response.\n- Set should_reply = false for promotional, spam, marketing, or newsletter emails.\n\nWhen should_reply is true, write a reply that is:\n- Polite, warm, and professional\n- Concise (2-5 short sentences)\n- Directly addressing the sender's message\n- Free of placeholders like [Name]; sign off generically (e.g. \"Best regards\")\n\nWhen should_reply is false, set reply to an empty string.\nReturn only the structured fields requested."
        }
      },
      "id": "86665073-7dd4-438f-827c-313c8b5519c8",
      "name": "AI Email Assistant",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        224,
        112
      ]
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-5-mini"
        },
        "builtInTools": {},
        "options": {}
      },
      "id": "a6d110f8-a8e7-4d07-9753-eec09180f27b",
      "name": "OpenAI GPT Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        240,
        336
      ],
      "credentials": {
        "openAiApi": {
          "id": null,
          "name": "",
          "__aiGatewayManaged": true
        }
      }
    },
    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\"type\":\"object\",\"properties\":{\"category\":{\"type\":\"string\",\"enum\":[\"genuine\",\"promotional\",\"spam\",\"newsletter\"],\"description\":\"The classification of the email\"},\"should_reply\":{\"type\":\"boolean\",\"description\":\"True only for genuine emails that warrant a reply\"},\"reply\":{\"type\":\"string\",\"description\":\"The professional reply text, or empty string when should_reply is false\"}},\"required\":[\"category\",\"should_reply\",\"reply\"]}"
      },
      "id": "f65d40a2-de7c-4636-aaae-97c853607689",
      "name": "Reply Decision Parser",
